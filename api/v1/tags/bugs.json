      "source": "Community sourced"
    },
    {
      "text": "The best engineers don't have fewer bugs. They catch them earlier. Shift left, not right.",
      "author": "based",
      "author_slug": "based",
      "categories": [
        "engineering"
      ],
      "tags": [

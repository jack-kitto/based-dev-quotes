      "source": "Community sourced"
    },
    {
      "text": "Every bug has a root cause. Find it. Don't just fix the symptom.",
      "author": "based",
      "author_slug": "based",
      "categories": [
        "engineering"
      ],
      "tags": [
        "bugs",
        "root-cause"

    },
    {
      "text": "Good design is as little design as possible. Less, but better.",
      "author": "Dieter Rams",
      "author_slug": "rams",
      "categories": [
        "design",
        "wisdom"
      ],
      "tags": [
        "simplicity",
        "minimalism"
      ],
      "grug_level": 3,
      "spiciness": 1,
      "id": "rams-good-design-is-as",
      "source": "Community sourced"
    },
    {
      "text": "Simplicity is not the absence of clutter; it's the presence of order.",
      "author": "Jonathan Ive",
      "author_slug": "ive",
      "categories": [
        "design"
      ],
      "tags": [
        "simplicity",
        "minimalism"
      ],
      "grug_level": 3,
      "spiciness": 1,
      "id": "ive-simplicity-is-not-the",
      "source": "Community sourced"
    },
    {
      "text": "If you need a user manual for your UI, you've already failed.",
      "author": "based",
      "author_slug": "based",
      "categories": [
        "design",
        "product"
      ],
      "tags": [

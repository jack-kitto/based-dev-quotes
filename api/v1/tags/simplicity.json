    },
    {
      "id": "hickey-simple-easy",
      "text": "Simple is not easy. Easy is near to our capabilities. Simple is about lack of interleaving. They are completely orthogonal.",
      "author": "Rich Hickey",
      "author_slug": "hickey",
      "source": "Simple Made Easy, Strange Loop 2011",
      "categories": [
        "wisdom",
        "complexity"
      ],
      "tags": [
        "simplicity",
        "complexity",
        "design"
      ],
      "grug_level": 3,
      "spiciness": 1
    },
    {
      "id": "blow-simplest-thing",
      "text": "I want the simplest possible thing that satisfies my actual requirements, and I want to understand every single line of it.",
      "author": "Jonathan Blow",
      "author_slug": "blow",
      "source": "Preventing the Collapse of Civilization, DevGAMM 2019",
      "categories": [
        "wisdom",
        "complexity"
      ],
      "tags": [
        "simplicity",
        "understanding",
        "control"
      ],
      "grug_level": 5,
      "spiciness": 2
    },
    {
      "id": "atwood-best-code",
      "text": "The best code is no code at all. Every new line of code you willingly bring into the world is code that has to be debugged, code that has to be read and understood, code that has to be supported.",
      "author": "Jeff Atwood",
      "author_slug": "atwood",
      "source": "The Best Code is No Code At All, 2007",
      "categories": [
        "wisdom",
        "complexity"
      ],
      "tags": [
        "less-code",
        "simplicity",
        "maintenance"
      ],
      "grug_level": 4,
      "spiciness": 1
    },
    {
      "id": "sandi-metz-wrong-abstraction",
      "text": "Duplication is far cheaper than the wrong abstraction.",

      "author_slug": "saint-exupery",
      "categories": [
        "wisdom",
        "engineering"
      ],
      "tags": [
        "simplicity",
        "perfection"
      ],
      "grug_level": 3,
      "spiciness": 1,
      "id": "saint-exupery-perfection-is-achieved-not",
      "source": "Community sourced"
    },
    {
      "text": "Simplicity does not precede complexity, but follows it.",
      "author": "Alan Perlis",
      "author_slug": "perlis",
      "categories": [
        "engineering",
        "wisdom"
      ],
      "tags": [
        "simplicity",
        "complexity"
      ],
      "grug_level": 3,
      "spiciness": 1,
      "id": "perlis-simplicity-does-not-precede",
      "source": "Community sourced"
    },
    {
      "text": "Worse is better.",
      "author": "Richard P. Gabriel",
      "author_slug": "gabriel",
      "categories": [
        "engineering",
        "wisdom"
      ],
      "tags": [
        "simplicity",
        "pragmatism"
      ],
      "grug_level": 3,

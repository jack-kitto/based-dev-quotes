      "id": "gabriel-worse-is-better",
      "source": "Community sourced"
    },
    {
      "text": "If you can't explain it simply, you don't understand it well enough.",
      "author": "Albert Einstein",
      "author_slug": "einstein",
      "categories": [
        "wisdom"
      ],
      "tags": [
        "simplicity",
        "understanding"
      ],
      "grug_level": 3,
      "spiciness": 1,
      "id": "einstein-if-you-cant-explain",
      "source": "Community sourced"
    },
    {
      "text": "The best engineers are the ones who know what not to build.",
      "author": "based",
      "author_slug": "based",
      "categories": [
        "engineering",
        "wisdom"
      ],
      "tags": [
        "discipline",
        "simplicity"
      ],
      "grug_level": 3,
      "spiciness": 2,
      "id": "based-the-best-engineers-are",
